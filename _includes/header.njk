<header>
  <nav>
    <!-- Logo / home link on the left -->
    {% set langBase = "/en" if lang == "en" else "" %}
    <a href="{{ (langBase ~ '/') | url }}">MANUEL COLOMBO{% if isStaging %} <span style="color: #8b00ff; font-size: 0.7em;">[STAGING]</span>{% endif %}</a>

    <!-- Right-side menu: ul replaces div.menu -->
    <ul>
      <li><a href="{{ (langBase ~ '/cv/') | url }}">CV</a></li>
      <li><a href="{{ (langBase ~ '/approach/') | url }}">Portfolio</a></li>
      <li><a href="{{ (langBase ~ '/blog/') | url }}">Blog</a></li>

      {# ── Language switcher: lang attribute replaces class ── #}
      {% set is_en = lang == "en" %}
      {% set is_it_blog_post = (not is_en) and (page.url | startsWith("/blog/")) and page.url != "/blog/" %}
      {% set is_en_blog_post = is_en and (page.url | startsWith("/en/blog/")) and page.url != "/en/blog/" %}

      {% if is_en %}
        {# English page → link back to Italian #}
        {% set it_url = page.url | replace("/en/", "/") %}
        <li><a href="{{ it_url | url }}" lang="it">IT</a></li>
      {% else %}
        {# Italian page → link to English #}
        {% set en_url = "/en" + page.url %}
        {% if is_it_blog_post %}
          {# Blog post: only show if EN translation exists #}
          {% if collections.blogEn | findByUrl(en_url) %}
            <li><a href="{{ en_url | url }}" lang="en">EN</a></li>
          {% else %}
            <li><span aria-disabled="true" title="Translation not yet available">EN</span></li>
          {% endif %}
        {% else %}
          {# Static page: EN version always exists #}
          <li><a href="{{ en_url | url }}" lang="en">EN</a></li>
        {% endif %}
      {% endif %}
    </ul>
  </nav>
</header>
